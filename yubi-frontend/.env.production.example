# Production build (`npm run build`) — copy to `.env.production` and adjust.
# Do not commit real secrets; `.env.production` is optional if defaults are correct.

# Backend API (must end with /). Falls back to https://www.yubi.co.in/api/ in src/lib/axios.js
# VITE_BASE_URL=https://www.yubi.co.in/api/

# If the app is hosted in a subfolder (must match Apache RewriteBase and router basename)
# VITE_BASE_PATH=/
